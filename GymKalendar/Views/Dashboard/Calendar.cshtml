@model List<GymKalendar.Models.Workout>
@{
    Layout = null;
    ViewData["Title"] = "Календарь тренировок";
    Context.Response.Headers["X-Disable-Layout"] = "true";

    DateTime startDate = DateTime.Today.AddYears(-1);
    DateTime endDate = new DateTime(2030, 12, 31);
    string currentMonthId = $"month-{DateTime.Today.Year}-{DateTime.Today.Month}";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymKalendar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-main: #0b0d13;
                --bg-card: #141824;
                --bg-sidebar: #111420;
                --border-color: #242b3e;
                --neon-blue: #3b82f6;
                --neon-green: #00ff87;
                --neon-lime: #ccff00;
            }

            body {
                background-color: var(--bg-main);
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                margin: 0;
                padding: 0;
                display: flex;
                min-height: 100vh;
            }

            .app-layout {
                display: flex;
                width: 100%;
            }

            /* --- МОНОЛИТНЫЙ SIDEBAR --- */
            .sidebar {
                width: 280px;
                background-color: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 30px 20px;
                position: fixed;
                height: 100vh;
                z-index: 100;
            }

            /* Полное растягивание по ширине экрана */
            .main-content {
                margin-left: 280px;
                flex-grow: 1;
                padding: 40px;
                width: calc(100% - 280px);
                animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            .brand-logo {
                font-size: 1.4rem;
                font-weight: 800;
                letter-spacing: -0.5px;
                background: linear-gradient(135deg, #3b82f6 0%, #ccff00 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 35px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .nav-menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .nav-item-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                color: #8a99ad;
                text-decoration: none;
                font-weight: 500;
                border-radius: 12px;
                transition: all 0.25s ease;
            }

                .nav-item-link:hover {
                    background-color: rgba(59, 130, 246, 0.1);
                    color: #ffffff;
                }

                /* На этой странице активным подсвечивается календарь */
                .nav-item-link.active {
                    border-left: 3px solid var(--neon-blue);
                    background-color: #1a2035;
                    color: #ffffff;
                }

                .nav-item-link.nav-calendar:hover {
                    background-color: rgba(204, 255, 0, 0.08);
                    color: var(--neon-lime);
                }

            .sidebar-footer {
                border-top: 1px solid var(--border-color);
                padding-top: 20px;
            }

            .btn-logout {
                display: flex;
                align-items: center;
                gap: 12px;
                width: 100%;
                background: transparent;
                border: 1px solid rgba(220, 53, 69, 0.2);
                color: #ea868f;
                padding: 12px 16px;
                border-radius: 12px;
                font-weight: 500;
                transition: all 0.2s ease;
            }

                .btn-logout:hover {
                    background: rgba(220, 53, 69, 0.1);
                    color: #ffffff;
                    border-color: #dc3545;
                }

            /* --- СТИЛИ КАЛЕНДАРЯ --- */
            .calendar-title {
                font-size: 2.2rem;
                font-weight: 700;
                background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .legend-wrapper {
                background-color: var(--bg-card);
                border: 1px solid var(--border-color);
                padding: 12px 24px;
                border-radius: 14px;
                display: inline-flex;
                gap: 24px;
            }

            .legend-dot {
                width: 12px;
                height: 12px;
                border-radius: 4px;
                display: inline-block;
            }

            .month-box {
                background-color: var(--bg-card);
                border-radius: 20px;
                padding: 24px;
                border: 1px solid var(--border-color);
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
                transition: all 0.3s ease;
                height: 100%;
            }

                .month-box:hover {
                    border-color: rgba(59, 130, 246, 0.3);
                    transform: translateY(-2px);
                }

                .month-box.current-month {
                    border: 1px solid rgba(204, 255, 0, 0.4);
                    box-shadow: 0 0 25px rgba(204, 255, 0, 0.05), 0 8px 32px rgba(0, 0, 0, 0.2);
                    background: linear-gradient(180deg, var(--bg-card) 0%, #171d2c 100%);
                }

            .days-grid {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                gap: 8px;
                text-align: center;
            }

            .day-name {
                font-weight: 700;
                color: #64748b;
                font-size: 0.75rem;
                text-transform: uppercase;
                padding-bottom: 8px;
            }

            .day-cell {
                aspect-ratio: 1;
                background-color: #1e2538;
                color: #cbd5e1;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                font-size: 0.9rem;
                cursor: pointer;
                transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
                user-select: none;
                border: 1px solid transparent;
            }

                .day-cell:hover {
                    background-color: #2d3748;
                    color: #ffffff;
                    transform: scale(1.08);
                }

                .day-cell.trained {
                    background: linear-gradient(135deg, #00ff87 0%, #00d26a 100%) !important;
                    color: #0b0d13 !important;
                    font-weight: 700;
                    box-shadow: 0 0 15px rgba(0, 255, 135, 0.4);
                    transform: scale(1.02);
                }

                    .day-cell.trained:hover {
                        box-shadow: 0 0 22px rgba(0, 255, 135, 0.6);
                    }

            .empty-cell {
                aspect-ratio: 1;
            }

            /* Эффект тряски при попытке кликнуть на будущую дату */
            @@keyframes shake {
                0%, 100% {
                    transform: translateX(0);
                }

                25% {
                    transform: translateX(-4px);
                }

                75% {
                    transform: translateX(4px);
                }
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(15px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* --- Сетка динамического расширения под экраны от края до края --- */
            @@media (min-width: 1400px) {
                .row-cols-lg-3 > * {
                    flex: 0 0 auto;
                    width: 25%; /* 4 месяца в ряд */
                }
            }

            @@media (min-width: 1800px) {
                .row-cols-lg-3 > * {
                    flex: 0 0 auto;
                    width: 20%; /* 5 месяцев в ряд */
                }
            }

            @@media (max-width: 992px) {
                body {
                    flex-direction: column;
                }

                .sidebar {
                    width: 100%;
                    height: auto;
                    position: relative;
                    padding: 20px;
                    border-right: none;
                    border-bottom: 1px solid var(--border-color);
                }

                .brand-logo {
                    margin-bottom: 20px;
                    justify-content: center;
                }

                .nav-menu {
                    flex-direction: row;
                    justify-content: center;
                    flex-wrap: wrap;
                }

                .sidebar-footer {
                    display: none;
                }

                .main-content {
                    margin-left: 0;
                    padding: 24px;
                    width: 100%;
                }

                .mobile-logout-wrapper {
                    display: block !important;
                }
            }
    </style>
</head>
<body>

    <div class="app-layout w-100">

        <!-- ИСПРАВЛЕННЫЙ СИНХРОННЫЙ SIDEBAR -->
        <aside class="sidebar">
            <div>
                <div class="brand-logo">
                    <i class="bi bi-lightning-charge-fill text-primary"></i>
                    <span>GymKalendar</span>
                </div>

                <nav class="nav-menu">
                    <a href="/Dashboard/Index" class="nav-item-link">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Главный экран</span>
                    </a>
                    <!-- Ссылка на шаблоны добавлена и синхронизирована с Index.cshtml -->
                    <a asp-controller="Workout" asp-action="Templates" class="nav-item-link">
                        <i class="bi bi-journal-bookmark-fill text-info"></i>
                        <span>Мои шаблоны</span>
                    </a>
                    <a href="/Profile/Index" class="nav-item-link">
                        <i class="bi bi-person-gear"></i>
                        <span>Настройки профиля</span>
                    </a>
                    <!-- Календарь активен на этой странице -->
                    <a href="#" class="nav-item-link active">
                        <i class="bi bi-calendar3-event text-warning"></i>
                        <span>Календарь занятий</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-footer">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Выйти из системы</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ОСНОВНОЙ КОНТЕНТ КАЛЕНДАРЯ -->
        <main class="main-content">

            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-5">
                <div>
                    <h1 class="calendar-title m-0">Календарь тренировок</h1>
                    <p class="text-light-muted m-0 mt-1">Кликни на день, чтобы отметить или отменить тренировку.</p>
                </div>

                <div class="legend-wrapper">
                    <div class="d-flex align-items-center gap-2">
                        <span class="legend-dot" style="background: linear-gradient(135deg, #00ff87 0%, #00d26a 100%); box-shadow: 0 0 8px rgba(0, 255, 135, 0.3);"></span>
                        <span class="small fw-medium" style="color: #cbd5e1;">День в зале</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="legend-dot" style="background-color: #1e2538;"></span>
                        <span class="small text-light-muted">Остальные дни</span>
                    </div>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

                @for (DateTime date = new DateTime(startDate.Year, startDate.Month, 1); date <= endDate; date = date.AddMonths(1))
                {
                    string monthName = date.ToString("MMMM", new System.Globalization.CultureInfo("ru-RU"));
                    monthName = char.ToUpper(monthName[0]) + monthName.Substring(1) + " " + date.Year;

                    int daysInMonth = DateTime.DaysInMonth(date.Year, date.Month);
                    int dayOfWeekOffset = ((int)date.DayOfWeek + 6) % 7;

                    bool isCurrent = (date.Year == DateTime.Today.Year && date.Month == DateTime.Today.Month);
                    string boxClass = isCurrent ? "month-box current-month" : "month-box";
                    string monthId = $"month-{date.Year}-{date.Month}";

                    <div class="col">
                        <div class="@boxClass" id="@monthId">
                            <h4 class="fw-bold mb-4 h5 d-flex justify-content-between align-items-center">
                                <span style="letter-spacing: -0.3px;">@monthName</span>
                                @if (isCurrent)
                                {
                                    <span class="badge bg-dark border font-monospace text-uppercase" style="font-size: 0.65rem; color: var(--neon-lime); border-color: rgba(204, 255, 0, 0.4) !important;">Текущий</span>
                                }
                            </h4>

                            <div class="days-grid">
                                <div class="day-name">Пн</div>
                                <div class="day-name">Вт</div>
                                <div class="day-name">Ср</div>
                                <div class="day-name">Чт</div>
                                <div class="day-name">Пт</div>
                                <div class="day-name">Сб</div>
                                <div class="day-name">Вс</div>

                                @for (int i = 0; i < dayOfWeekOffset; i++)
                                {
                                    <div class="empty-cell"></div>
                                }

                                @for (int day = 1; day <= daysInMonth; day++)
                                {
                                    DateTime loopDate = new DateTime(date.Year, date.Month, day);
                                    string fullDateStr = loopDate.ToString("yyyy-MM-dd");
                                    bool isTrained = ViewBag.TrainedDays != null && ((List<string>)ViewBag.TrainedDays).Contains(fullDateStr);

                                    if (loopDate > DateTime.Today)
                                    {
                                        <!-- Будущие дни: визуально приглушены -->
                                        <div class="day-cell" data-date="@fullDateStr" onclick="toggleDay(this)" style="opacity: 0.3; cursor: not-allowed;">
                                            @day
                                        </div>
                                    }
                                    else
                                    {
                                        string trainedClass = isTrained ? "day-cell trained" : "day-cell";
                                        <div class="@trainedClass" data-date="@fullDateStr" onclick="toggleDay(this)">
                                            @day
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mobile-logout-wrapper d-none mt-5 pt-3 border-top border-secondary">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger w-100 py-2.5">
                        <i class="bi bi-box-arrow-right me-2"></i>Выйти из аккаунта
                    </button>
                </form>
            </div>

        </main>
    </div>

    <script>
            function toggleDay(element) {
                const dateStr = element.getAttribute('data-date');

                // Клиентская проверка на будущую дату
                const todayStr = new Date().toISOString().split('T')[0];
                if (dateStr > todayStr) {
                    // Анимация тряски
                    element.style.animation = 'none';
                    setTimeout(() => element.style.animation = 'shake 0.3s', 10);
                    return;
                }

                fetch('/Dashboard/ToggleDay?dateString=' + dateStr, {
                    method: 'POST'
                })
                .then(response => {
                    if (response.ok) {
                        element.classList.toggle('trained');
                    } else {
                        alert('Не удалось сохранить день тренировки.');
                    }
                })
                .catch(error => console.error('Ошибка:', error));
            }

            document.addEventListener("DOMContentLoaded", function () {
                const currentMonthElement = document.getElementById("@currentMonthId");
                if (currentMonthElement) {
                    currentMonthElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            });
    </script>
</body>
</html>
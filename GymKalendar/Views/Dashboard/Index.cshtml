@model List<GymKalendar.Models.Workout>
@{
    Layout = null;
    Context.Response.Headers["X-Disable-Layout"] = "true";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Панель управления — GymKalendar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-main: #0b0d13;
                --bg-card: #141824;
                --bg-sidebar: #111420;
                --border-color: #242b3e;
                --neon-blue: #3b82f6;
                --neon-lime: #ccff00;
            }

            body {
                background-color: var(--bg-main);
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                margin: 0;
                padding: 0;
                display: flex;
                min-height: 100vh;
            }

            /* --- СТРУКТУРНАЯ СЕТКА (SIDEBAR + MAIN CONTENT) --- */
            .app-layout {
                display: flex;
                width: 100%;
            }

            .sidebar {
                width: 280px;
                background-color: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 30px 20px;
                position: fixed;
                height: 100vh;
                z-index: 100;
            }

            .main-content {
                margin-left: 280px;
                flex-grow: 1;
                padding: 40px;
                max-width: 1200px;
                animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            /* --- ЛОГОТИП И НАВИГАЦИЯ В МЕНЮ --- */
            .brand-logo {
                font-size: 1.4rem;
                font-weight: 800;
                letter-spacing: -0.5px;
                background: linear-gradient(135deg, #3b82f6 0%, #ccff00 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 35px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .nav-menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .nav-item-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                color: #8a99ad;
                text-decoration: none;
                font-weight: 500;
                border-radius: 12px;
                transition: all 0.25s ease;
            }

                .nav-item-link:hover, .nav-item-link.active {
                    background-color: rgba(59, 130, 246, 0.1);
                    color: #ffffff;
                }

                .nav-item-link.active {
                    border-left: 3px solid var(--neon-blue);
                    background-color: #1a2035;
                }

                .nav-item-link.nav-calendar:hover {
                    background-color: rgba(204, 255, 0, 0.08);
                    color: var(--neon-lime);
                }

            /* --- БЛОК ВЫХОДА ВНИЗУ МЕНЮ --- */
            .sidebar-footer {
                border-top: 1px solid var(--border-color);
                padding-top: 20px;
            }

            .btn-logout {
                display: flex;
                align-items: center;
                gap: 12px;
                width: 100%;
                background: transparent;
                border: 1px solid rgba(220, 53, 69, 0.2);
                color: #ea868f;
                padding: 12px 16px;
                border-radius: 12px;
                font-weight: 500;
                transition: all 0.2s ease;
            }

                .btn-logout:hover {
                    background: rgba(220, 53, 69, 0.1);
                    color: #ffffff;
                    border-color: #dc3545;
                }

            /* --- ХЕДЕР И ПРИВЕТСТВИЕ --- */
            .welcome-title {
                font-size: 2.2rem;
                font-weight: 700;
                background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            /* --- ВИДЖЕТЫ СТАТИСТИКИ --- */
            .stat-card {
                background: var(--bg-card);
                border-radius: 16px;
                border: 1px solid var(--border-color);
                border-left: 4px solid var(--neon-blue);
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
                transition: transform 0.2s ease;
            }

                .stat-card:hover {
                    transform: translateY(-3px);
                }

                .stat-card.accent-neon {
                    border-left-color: var(--neon-lime);
                }

            .text-neon {
                color: var(--neon-lime);
            }

            /* --- ИСТОРИЯ ТРЕНИРОВОК --- */
            .btn-custom-create {
                background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
                color: #ffffff;
                border: none;
                border-radius: 12px;
                font-weight: 600;
                padding: 10px 20px;
                box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
                text-transform: uppercase;
                font-size: 0.8rem;
                letter-spacing: 0.5px;
                transition: all 0.2s ease;
                text-decoration: none;
            }

                .btn-custom-create:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
                    color: #ffffff;
                }

            .workout-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
                gap: 20px;
                margin-top: 20px;
            }

            .workout-card {
                background: var(--bg-card);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                padding: 24px;
                transition: all 0.25s ease;
                cursor: pointer;
                position: relative;
            }

                .workout-card:hover {
                    transform: translateY(-4px);
                    border-color: var(--neon-blue);
                    background-color: #1c2234;
                    box-shadow: 0 10px 25px rgba(59, 130, 246, 0.15);
                }

            .workout-title {
                font-size: 1.25rem;
                font-weight: 700;
                margin-bottom: 12px;
                color: #fff;
            }

            .workout-date {
                font-size: 0.85rem;
                color: #8a99ad;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .empty-state {
                text-align: center;
                padding: 50px 20px;
                background: var(--bg-card);
                border-radius: 16px;
                border: 2px dashed var(--border-color);
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(15px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* --- ТАКТИЧЕСКИЙ RESPONSIVE (МЕДИА-ЗАПРОСЫ) --- */
            @@media (max-width: 992px) {
                body {
                    flex-direction: column;
                }

                .sidebar {
                    width: 100%;
                    height: auto;
                    position: relative;
                    padding: 20px;
                    border-right: none;
                    border-bottom: 1px solid var(--border-color);
                }

                .brand-logo {
                    margin-bottom: 20px;
                    justify-content: center;
                }

                .nav-menu {
                    flex-direction: row;
                    justify-content: center;
                    flex-wrap: wrap;
                }

                .sidebar-footer {
                    display: none;
                }
                /* Спрячем в мобилке нижнюю кнопку выхода */
                .main-content {
                    margin-left: 0;
                    padding: 24px;
                }

                .mobile-logout-wrapper {
                    display: block !important;
                }
            }
    </style>
</head>
<body>

    <div class="app-layout w-100">

        <!-- МОНОЛИТНЫЙ СТИЛЬНЫЙ SIDEBAR -->
        <aside class="sidebar">
            <div>
                <div class="brand-logo">
                    <i class="bi bi-lightning-charge-fill text-primary"></i>
                    <span>GymKalendar</span>
                </div>

                <nav class="nav-menu">
                    <a href="#" class="nav-item-link active">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Главный экран</span>
                    </a>
                    <a href="/Profile/Index" class="nav-item-link">
                        <i class="bi bi-person-gear"></i>
                        <span>Настройки профиля</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="Calendar" class="nav-item-link nav-calendar">
                        <i class="bi bi-calendar3-event text-warning"></i>
                        <span>Календарь занятий</span>
                    </a>
                </nav>
            </div>

            <!-- Выход из аккаунта (Всегда на своем месте внизу меню) -->
            <div class="sidebar-footer">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Выйти из системы</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ОСНОВНОЙ КОНТЕНТ ДАШБОРДА -->
        <main class="main-content">

            <!-- Блок приветствия -->
            <div class="mb-4">
                <h1 class="welcome-title m-0">Привет, @ViewBag.SportsmanName! 💪🔥</h1>
                <p class="text-light-muted m-0 mt-1">Рад видеть тебя снова. Все показатели в норме.</p>
            </div>

            <!-- Блок Экспресс-статистики -->
            <div class="row g-3 mb-5">
                <div class="col-6 col-md-3">
                    <div class="card stat-card border-0 h-100">
                        <div class="card-body p-3.5">
                            <span class="text-light small d-block mb-1">Всего тренировок</span>
                            <span class="h3 fw-bold text-light">@(Model?.Count ?? 0)</span>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card stat-card accent-neon border-0 h-100">
                        <div class="card-body p-3.5">
                            <span class="text-light small d-block mb-1">Текущий стрик</span>
                            <span class="h3 fw-bold text-neon">🔥 @(Model?.Count > 0 ? "Активен" : "0 дней")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Раздел Истории тренировок -->
            <div class="workout-section">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-x h1 text-muted d-block mb-3"></i>
                        <p>История тренировок пуста. Создай свою первую сессию прямо сейчас!</p>
                        <a href="/Workout/Create" class="btn-custom-create d-inline-block">Записать тренировку</a>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="h4 text-light fw-bold m-0">История тренировок</h2>
                        <a href="/Workout/Create" class="btn-custom-create">
                            <i class="bi bi-plus-lg me-1"></i> Создать
                        </a>
                    </div>

                  

                    <div class="workout-grid">
                        @foreach (var workout in Model)
                        {
                            <div class="workout-card" onclick="location.href='/Workout/Details/@workout.Id'">
                                <h3 class="workout-title">@workout.Name</h3>
                                <div class="workout-date">
                                    <i class="bi bi-calendar3 text-primary"></i>
                                    <span>@workout.Date.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Резервная мобильная кнопка выхода (появляется только на узких экранах вместо сайдбара) -->
            <div class="mobile-logout-wrapper d-none mt-5 pt-3 border-top border-secondary">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger w-100 py-2.5">
                        <i class="bi bi-box-arrow-right me-2"></i>Выйти из аккаунта
                    </button>
                </form>
            </div>

        </main>
    </div>

</body>
</html>
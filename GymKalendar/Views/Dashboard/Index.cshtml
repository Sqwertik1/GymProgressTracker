@model List<GymKalendar.Models.Workout>

@{
    Layout = null;
    Context.Response.Headers["X-Disable-Layout"] = "true"; // Хак для кэша, если нужно
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Личный кабинет — GymKalendar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            /* Глобальные стили темы GymKalendar */
            body {
                background-color: #12141c;
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                padding: 40px 0;
            }

            .container {
                max-width: 1050px;
            }

            h1 {
                font-size: 2.2rem;
                color: #ffffff;
            }

            .text-light-muted {
                color: #a0aec0;
            }

            /* Быстрая статистика дашборда */
            .stat-card {
                background-color: #1a1f2c;
                border-radius: 14px;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
                border-left: 4px solid #3b82f6;
                transition: transform 0.2s ease;
            }

                .stat-card:hover {
                    transform: translateY(-2px);
                }

                .stat-card.accent-neon {
                    border-left-color: #ccff00;
                }

            .text-neon {
                color: #ccff00;
            }

            /* Общие стили для кнопок */
            .btn-custom {
                background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
                color: #ffffff;
                border: none;
                border-radius: 10px;
                font-weight: 600;
                box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
                transition: all 0.2s ease;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                font-size: 0.9rem;
            }

                .btn-custom:hover {
                    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
                    color: #ffffff;
                    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
                    transform: translateY(-1px);
                }

            /* Сетка и карточки тренировок */
            .workout-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
                gap: 20px;
                margin-top: 20px;
            }

            .workout-card {
                background: #1e2538;
                border: 1px solid #2d3748;
                border-radius: 14px;
                padding: 22px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.2);
                transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                cursor: pointer;
                position: relative;
                overflow: hidden;
            }

                /* Эффект свечения при наведении на тренировку */
                .workout-card:hover {
                    transform: translateY(-4px);
                    border-color: #3b82f6;
                    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.2);
                }

                .workout-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 4px;
                    height: 100%;
                    background-color: #3b82f6;
                    opacity: 0;
                    transition: opacity 0.2s;
                }

                .workout-card:hover::before {
                    opacity: 1;
                }

            .workout-title {
                font-size: 1.25rem;
                font-weight: 700;
                margin: 0 0 12px 0;
                color: #ffffff;
                line-height: 1.3;
            }

            .workout-date {
                font-size: 0.85rem;
                color: #a0aec0;
                display: flex;
                align-items: center;
                gap: 6px;
            }

            /* Пустое состояние (Empty State) */
            .empty-state {
                text-align: center;
                padding: 60px 20px;
                background: #1a1f2c;
                border-radius: 16px;
                border: 2px dashed #2d3748;
                margin-top: 20px;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
            }

                .empty-state p {
                    font-size: 1.2rem;
                    color: #a0aec0;
                    margin-bottom: 24px;
                }

            .empty-icon {
                font-size: 3rem;
                color: #4a5568;
                margin-bottom: 15px;
                display: block;
            }
    </style>
</head>
<body>

    <div class="container px-3">

        <!-- Приветственная верхняя секция -->
        <div class="row align-items-center mb-4 g-3">
            <div class="col-12 col-sm-8">
                <h1 class="fw-bold m-0">Привет, @ViewBag.SportsmanName! 💪🔥</h1>
                <p class="text-light-muted m-0 mt-1">Добро пожаловать обратно в свой тренировочный хаб.</p>
            </div>
        </div>

        <!-- Виджеты крутой мини-статистики (берут данные прямо из твоей модели тренировок) -->
        <div class="row g-3 mb-5">
            <div class="col-6 col-md-3">
                <div class="card stat-card border-0 h-100">
                    <div class="card-body p-3">
                        <span class="text-light-muted small d-block mb-1">Всего сессий</span>
                        <span class="h3 fw-bold text-light">@(Model?.Count ?? 0)</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card stat-card accent-neon border-0 h-100">
                    <div class="card-body p-3">
                        <span class="text-light-muted small d-block mb-1">Текущий стрик</span>
                        <span class="h3 fw-bold text-neon">🔥 @(Model?.Count > 0 ? "Активен" : "0 дней")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основная секция истории тренировок -->
        <div class="workout-section">

            @if (Model == null || Model.Count == 0)
            {
                <!-- ЕСЛИ ТРЕНИРОВОК НЕТ -->
                <div class="empty-state">
                    <i class="bi bi-calendar-x empty-icon"></i>
                    <p>История тренировок пока пуста. Пора положить этому начало!</p>
                    <a href="/Workout/Create" class="btn btn-custom px-4 py-2.5">
                        <i class="bi bi-plus-lg me-2"></i>Записать тренировку
                    </a>
                </div>
            }
            else
            {
                <!-- ЕСЛИ ТРЕНИРОВКИ ЕСТЬ -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="h4 text-light fw-bold m-0">История тренировок</h2>
                    <a href="/Workout/Create" class="btn btn-custom px-3 py-2">
                        <i class="bi bi-plus-lg me-1"></i> Создать
                    </a>
                </div>

                <!-- Умная CSS-Grid сетка карточек -->
                <div class="workout-grid">
                    @foreach (var workout in Model)
                    {
                        <div class="workout-card" onclick="location.href='/Workout/Details/@workout.Id'">
                            <h3 class="workout-title">@workout.Name</h3>
                            <div class="workout-date">
                                <i class="bi bi-calendar3 text-accent-blue"></i>
                                <span>@workout.Date.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

</body>
</html>
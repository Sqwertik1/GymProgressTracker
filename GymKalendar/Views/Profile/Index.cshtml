@model GymKalendar.Models.ProfileViewModel
@{
    Layout = null;
    ViewData["Title"] = "Профиль пользователя";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymKalendar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            body {
                background-color: #12141c;
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                padding: 40px 0;
            }

            .container {
                max-width: 600px;
            }

            .text-light-muted {
                color: #a0aec0;
            }

            .text-accent-blue {
                color: #3b82f6;
            }

            .profile-card {
                background-color: #1a1f2c;
                border-radius: 16px;
                box-shadow: 0 4px 25px rgba(0, 0, 0, 0.3);
            }
            /* Стилизация строк с данными */
            .info-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 12px 0;
                border-bottom: 1px solid #2d3748;
            }

                .info-row:last-child {
                    border-bottom: none;
                }

            .info-label {
                color: #a0aec0;
                font-weight: 500;
            }

            .info-value {
                color: #ffffff;
                font-weight: 600;
            }
            /* Главная кнопка */
            .btn-custom {
                background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
                color: #ffffff;
                border: none;
                border-radius: 10px;
                font-weight: 600;
                box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
                transition: all 0.2s ease;
            }

                .btn-custom:hover {
                    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
                    color: #ffffff;
                    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
                    transform: translateY(-1px);
                }

            .btn-back-dashboard {
                color: #a0aec0;
                text-decoration: none;
                transition: color 0.2s;
            }

                .btn-back-dashboard:hover {
                    color: #ffffff;
                }
    </style>
</head>
<body>

    <div class="container px-3">

        <div class="mb-4">
            <a href="/Dashboard/Index" class="btn-back-dashboard small fw-semibold">
                <i class="bi bi-arrow-left me-1"></i> Вернуться на главную
            </a>
        </div>

        <h2 class="fw-bold mb-4 text-light">Личный кабинет</h2>

        <div class="card profile-card border-0 mb-4">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold text-light mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-person-circle text-accent-blue"></i> Основная информация
                </h3>
                <div class="info-list">
                    <div class="info-row">
                        <span class="info-label">Имя:</span>
                        <span class="info-value">@Model.Name</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Фамилия:</span>
                        <span class="info-value">@(string.IsNullOrEmpty(Model.LastName) ? "—" : Model.LastName)</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Возраст:</span>
                        <span class="info-value">@Model.Age</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email:</span>
                        <span class="info-value text-break">@Model.Email</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Телефон:</span>
                        <span class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card profile-card border-0 mb-4">
            <div class="card-body p-4">
                <h3 class="h5 fw-bold text-light mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-activity text-accent-blue"></i> Физические показатели
                </h3>
                <div class="info-list">
                    <div class="info-row">
                        <span class="info-label">Рост:</span>
                        <span class="info-value">@(Model.Height > 0 ? $"{Model.Height} см" : "—")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Вес:</span>
                        <span class="info-value">@(Model.Weight > 0 ? $"{Model.Weight} кг" : "—")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Уровень активности:</span>
                        <span class="info-value">@(Model.ActivityLevel > 0 ? $"{Model.ActivityLevel} / 5" : "—")</span>
                    </div>
                    <div class="info-row mt-3 pt-3 border-top border-secondary">
                        <span class="info-label text-success fw-bold">Твой примерный расход ккал:</span>
                        <span class="info-value text-success fw-bold">
                            @(Model.Calories > 0 ? $"{Model.Calories} ккал / день" : "Заполните данные для расчета")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2">
            <a asp-action="Save" class="btn btn-custom py-3 text-center">
                <i class="bi bi-pencil-square me-2"></i> Изменить физические данные
            </a>
        </div>

    </div>

</body>
</html>
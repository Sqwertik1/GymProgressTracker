@model GymKalendar.Models.ProfileViewModel
@{
    Layout = null;
    ViewData["Title"] = "Редактирование параметров";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymKalendar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                background-color: #12141c;
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                padding: 40px 0;
            }

            .container {
                max-width: 550px;
            }

            .text-light-muted {
                color: #a0aec0;
            }

            .edit-card {
                background-color: #1a1f2c;
                border-radius: 16px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
                border-top: 4px solid #3b82f6;
            }

            .custom-input {
                background-color: #131722;
                border: 1px solid #2d3748;
                color: #ffffff;
                border-radius: 8px;
                padding: 0.75rem 1rem;
                transition: all 0.2s ease-in-out;
            }

                .custom-input:focus {
                    background-color: #161b29;
                    border-color: #3b82f6;
                    color: #ffffff;
                    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25);
                }

            .btn-save {
                background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
                color: #ffffff;
                border: none;
                border-radius: 10px;
                font-weight: 600;
                transition: all 0.2s ease;
            }

                .btn-save:hover {
                    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
                    color: #ffffff;
                    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
                }

            .btn-cancel {
                background-color: transparent;
                border: 1px solid #2d3748;
                color: #a0aec0;
                border-radius: 10px;
                transition: all 0.2s;
            }

                .btn-cancel:hover {
                    background-color: rgba(255,255,255,0.05);
                    color: #ffffff;
                }
    </style>
</head>
<body>

    <div class="container px-3">
        <div class="card edit-card border-0">
            <div class="card-body p-4 p-sm-5">

                <div class="mb-4 text-center text-sm-start">
                    <h2 class="fw-bold text-light mb-1">Изменение параметров</h2>
                    <p class="text-light-muted small">Обновите метрики тела для точного расчета тренировочных нагрузок</p>
                </div>

                <form asp-action="Save" method="post" autocomplete="off">
                    <input type="hidden" asp-for="Name" />
                    <input type="hidden" asp-for="LastName" />
                    <input type="hidden" asp-for="Age" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Phone" />

                    <div class="form-group mb-3">
                        <label asp-for="Height" class="form-label text-light-muted small fw-semibold">Рост (см)</label>
                        <input asp-for="Height" class="form-control custom-input" type="number" step="0.1" min="0" placeholder="Например: 180" />
                        <span asp-validation-for="Height" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Weight" class="form-label text-light-muted small fw-semibold">Вес (кг)</label>
                        <input asp-for="Weight" class="form-control custom-input" type="number" step="0.1" min="0" placeholder="Например: 75" />
                        <span asp-validation-for="Weight" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="ActivityLevel" class="form-label text-light-muted small fw-semibold">Уровень активности (1-5)</label>
                        <input asp-for="ActivityLevel" class="form-control custom-input" type="number" min="1" max="5" placeholder="1 — минимум, 5 — хардкорный спорт" />
                        <span asp-validation-for="ActivityLevel" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="row g-2 pt-2">
                        <div class="col-6">
                            <button type="submit" class="btn btn-save w-100 py-2.5">Сохранить</button>
                        </div>
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-cancel w-100 py-2.5 text-center text-decoration-none">Отмена</a>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
</body>
</html>
@model GymKalendar.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Регистрация — GymKalendar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                background-color: #12141c;
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .auth-card {
                background-color: #1a1f2c;
                border-radius: 16px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
                width: 100%;
                max-width: 550px;
                border-top: 4px solid #3b82f6;
            }

            .text-light-muted {
                color: #a0aec0;
            }

            .custom-input {
                background-color: #131722;
                border: 1px solid #2d3748;
                color: #ffffff;
                border-radius: 8px;
                padding: 0.75rem 1rem;
                transition: all 0.2s ease-in-out;
            }

                .custom-input:focus {
                    background-color: #161b29;
                    border-color: #3b82f6;
                    color: #ffffff;
                    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.25);
                }

                .custom-input::placeholder {
                    color: #4a5568;
                    font-size: 0.9rem;
                }

            .btn-submit-auth {
                background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
                color: #ffffff;
                border: none;
                border-radius: 10px;
                box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
                transition: all 0.2s ease;
            }

                .btn-submit-auth:hover {
                    background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
                    color: #ffffff;
                    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
                    transform: translateY(-1px);
                }

                .btn-submit-auth:active {
                    transform: translateY(1px);
                }

            .auth-link {
                color: #3b82f6;
                text-decoration: none;
                transition: color 0.2s ease;
            }

                .auth-link:hover {
                    color: #60a5fa;
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="p-3 w-100 d-flex justify-content-center">
        <div class="card auth-card border-0">
            <div class="card-body p-4 p-sm-5">

                <div class="title text-center mb-4">
                    <h1 class="h3 text-light fw-bold mb-1">Регистрация</h1>
                    <p class="text-light-muted small">Создайте аккаунт для доступа к календарю тренировок</p>
                </div>

                <!-- Блок валидации в стиле темной темы -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger bg-danger-subtle border-0 text-danger small p-3 mb-4 rounded-3"></div>
                }

                <form asp-controller="Home" asp-action="Register" method="post" autocomplete="off">

                    <!-- Имя и Фамилия в один ряд -->
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-sm-6">
                            <label class="form-label text-light-muted small fw-semibold">Имя:</label>
                            <input asp-for="FirstName" type="text" class="form-control custom-input" placeholder="Иван" required />
                        </div>
                        <div class="col-12 col-sm-6">
                            <label class="form-label text-light-muted small fw-semibold">Фамилия:</label>
                            <input asp-for="LastName" type="text" class="form-control custom-input" placeholder="Иванов" />
                        </div>
                    </div>

                    <!-- Возраст и Телефон в один ряд -->
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-sm-4">
                            <label class="form-label text-light-muted small fw-semibold">Возраст:</label>
                            <input asp-for="Age" type="number" class="form-control custom-input" placeholder="20" min="1" max="120" required />
                        </div>
                        <div class="col-12 col-sm-8">
                            <label class="form-label text-light-muted small fw-semibold">Телефон:</label>
                            <input asp-for="Phone" type="text" class="form-control custom-input" placeholder="+358 40 1234567" required />
                        </div>
                    </div>

                    <!-- Почта -->
                    <div class="mb-3">
                        <label class="form-label text-light-muted small fw-semibold">Почта:</label>
                        <input asp-for="Email" type="email" class="form-control custom-input" placeholder="example@mail.com" required />
                    </div>

                    <!-- Пароль -->
                    <div class="mb-4">
                        <label class="form-label text-light-muted small fw-semibold">Пароль:</label>
                        <input asp-for="Password" type="password" class="form-control custom-input" placeholder="••••••••" required />
                    </div>

                    <!-- Кнопка регистрации -->
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-submit-auth py-2.5 fw-bold">Зарегистрироваться</button>
                    </div>

                    <!-- Ссылка на логин -->
                    <div class="link text-center mt-4">
                        <a href="/Home/Login" class="auth-link small fw-semibold">Уже есть аккаунт? Войти</a>
                    </div>

                </form>
            </div>
        </div>
    </div>

</body>
</html>
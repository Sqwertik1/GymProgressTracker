@model IEnumerable<GymKalendar.Models.WorkoutTemplate>
@{
    Layout = null;
    ViewData["Title"] = "Мои шаблоны";
    Context.Response.Headers["X-Disable-Layout"] = "true";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymKalendar</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts (Inter) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-main: #0b0d13;
                --bg-card: #141824;
                --bg-sidebar: #111420;
                --border-color: #242b3e;
                --neon-blue: #3b82f6;
                --neon-green: #00ff87;
                --neon-lime: #ccff00;
            }

            body {
                background-color: var(--bg-main);
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                margin: 0;
                padding: 0;
                display: flex;
                min-height: 100vh;
            }

            .app-layout {
                display: flex;
                width: 100%;
            }

            /* --- САЙДБАР --- */
            .sidebar {
                width: 280px;
                background-color: var(--bg-sidebar);
                border-right: 1px solid var(--border-color);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 30px 20px;
                position: fixed;
                height: 100vh;
                z-index: 100;
            }

            /* Растягивание контента на 100% ширины */
            .main-content {
                margin-left: 280px;
                flex-grow: 1;
                padding: 40px;
                width: calc(100% - 280px);
                animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            }

            .brand-logo {
                font-size: 1.4rem;
                font-weight: 800;
                letter-spacing: -0.5px;
                background: linear-gradient(135deg, #3b82f6 0%, #ccff00 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 35px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .nav-menu {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

            .nav-item-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 16px;
                color: #8a99ad;
                text-decoration: none;
                font-weight: 500;
                border-radius: 12px;
                transition: all 0.25s ease;
            }

                .nav-item-link:hover {
                    background-color: rgba(59, 130, 246, 0.1);
                    color: #ffffff;
                }

                .nav-item-link.active {
                    border-left: 3px solid var(--neon-blue);
                    background-color: #1a2035;
                    color: #ffffff;
                }

                .nav-item-link.nav-calendar:hover {
                    background-color: rgba(204, 255, 0, 0.08);
                    color: var(--neon-lime);
                }

            .sidebar-footer {
                border-top: 1px solid var(--border-color);
                padding-top: 20px;
            }

            .btn-logout {
                display: flex;
                align-items: center;
                gap: 12px;
                width: 100%;
                background: transparent;
                border: 1px solid rgba(220, 53, 69, 0.2);
                color: #ea868f;
                padding: 12px 16px;
                border-radius: 12px;
                font-weight: 500;
                transition: all 0.2s ease;
            }

                .btn-logout:hover {
                    background: rgba(220, 53, 69, 0.1);
                    color: #ffffff;
                    border-color: #dc3545;
                }

            /* --- СТИЛИ КОНТЕНТА ШАБЛОНОВ --- */
            .page-title {
                font-size: 2.2rem;
                font-weight: 700;
                background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .template-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 24px;
            }

            .template-card {
                background-color: var(--bg-card);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                padding: 24px;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                height: 100%;
            }

                .template-card:hover {
                    border-color: var(--neon-blue);
                    transform: translateY(-4px);
                    box-shadow: 0 12px 30px rgba(59, 130, 246, 0.15);
                    background-color: #1c2234;
                }

            .template-title {
                font-size: 1.3rem;
                font-weight: 700;
                color: #ffffff;
                margin-bottom: 6px;
            }

            /* Кнопки действий */
            .btn-start-workout {
                background: linear-gradient(135deg, #00ff87 0%, #00d26a 100%);
                color: #0b0d13;
                font-weight: 700;
                border: none;
                border-radius: 12px;
                padding: 12px;
                box-shadow: 0 4px 15px rgba(0, 255, 135, 0.2);
                transition: all 0.2s ease;
                text-decoration: none;
                display: block;
                text-align: center;
            }

                .btn-start-workout:hover {
                    box-shadow: 0 6px 20px rgba(0, 255, 135, 0.4);
                    transform: scale(1.02);
                    color: #0b0d13;
                }

            .btn-delete-template {
                background: transparent;
                border: 1px solid rgba(239, 68, 68, 0.3);
                color: #ef4444;
                font-weight: 500;
                border-radius: 12px;
                padding: 10px;
                transition: all 0.2s ease;
            }

                .btn-delete-template:hover {
                    background: rgba(239, 68, 68, 0.1);
                    border-color: #ef4444;
                    color: #ffffff;
                }

            .empty-state {
                text-align: center;
                padding: 60px 20px;
                background: var(--bg-card);
                border-radius: 20px;
                border: 2px dashed var(--border-color);
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(15px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* Адаптивная сетка под ультраширокие мониторы */
            @@media (min-width: 1400px) {
                .template-grid {
                    grid-template-columns: repeat(4, 1fr);
                }
            }

            @@media (min-width: 1800px) {
                .template-grid {
                    grid-template-columns: repeat(5, 1fr);
                }
            }

            /* Мобильная адаптивность */
            @@media (max-width: 992px) {
                body {
                    flex-direction: column;
                }

                .sidebar {
                    width: 100%;
                    height: auto;
                    position: relative;
                    padding: 20px;
                    border-right: none;
                    border-bottom: 1px solid var(--border-color);
                }

                .brand-logo {
                    margin-bottom: 20px;
                    justify-content: center;
                }

                .nav-menu {
                    flex-direction: row;
                    justify-content: center;
                    flex-wrap: wrap;
                }

                .sidebar-footer {
                    display: none;
                }

                .main-content {
                    margin-left: 0;
                    padding: 24px;
                    width: 100%;
                }

                .mobile-logout-wrapper {
                    display: block !important;
                }
            }
    </style>
</head>
<body>

    <div class="app-layout w-100">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div>
                <div class="brand-logo">
                    <i class="bi bi-lightning-charge-fill text-primary"></i>
                    <span>GymKalendar</span>
                </div>

                <nav class="nav-menu">
                    <a href="/Dashboard/Index" class="nav-item-link">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Главный экран</span>
                    </a>
                    <!-- Активная вкладка "Мои шаблоны" -->
                    <a href="#" class="nav-item-link active">
                        <i class="bi bi-journal-bookmark-fill"></i>
                        <span>Мои шаблоны</span>
                    </a>
                    <a href="/Profile/Index" class="nav-item-link">
                        <i class="bi bi-person-gear"></i>
                        <span>Настройки профиля</span>
                    </a>
                    <a asp-controller="Dashboard" asp-action="Calendar" class="nav-item-link nav-calendar">
                        <i class="bi bi-calendar3-event text-warning"></i>
                        <span>Календарь занятий</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-footer">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Выйти из системы</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ОСНОВНОЙ КОНТЕНТ СТРАНИЦЫ ШАБЛОНОВ -->
        <main class="main-content">

            <div class="mb-5">
                <h1 class="page-title m-0">Мои шаблоны тренировок</h1>
                <p class="text-light-muted m-0 mt-1">Быстрый запуск уже настроенных тренировочных планов сессий.</p>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-journal-x h1 text-muted d-block mb-3"></i>
                    <p class="text-light-muted">У тебя пока нет сохраненных шаблонов.</p>
                    <p class="small text-muted">Ты можешь создать их из истории завершенных тренировок!</p>
                    <a href="/Dashboard/Index" class="btn btn-outline-primary btn-sm mt-2">Перейти к истории</a>
                </div>
            }
            else
            {
                <div class="template-grid">
                    @foreach (var template in Model)
                    {
                        <div class="template-card">
                            <div class="mb-4">
                                <h3 class="template-title">@template.Name</h3>
                                <span class="badge bg-dark-subtle text-info border border-info-subtle px-2 py-1 rounded small" style="font-size: 0.75rem;">
                                    <i class="bi bi-check2-circle me-1"></i> Готов к запуску
                                </span>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                <!-- Запуск тренировки -->
                                <a asp-controller="Workout"
                                   asp-action="StartWorkoutfromTemplate"
                                   asp-route-templateId="@template.Id"
                                   class="btn-start-workout">
                                    <i class="bi bi-play-fill me-1"></i> Начать тренировку
                                </a>

                                <!-- Форма удаления шаблона -->
                                <form asp-controller="Workout" asp-action="DeleteTemplate" asp-route-templateId="@template.Id" method="post" class="m-0 w-100">
                                    <button type="submit" class="btn-delete-template w-100" onclick="return confirm('Ты уверен, что хочешь удалить этот шаблон?');">
                                        <i class="bi bi-trash me-1"></i> Удалить шаблон
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Мобильная кнопка выхода -->
            <div class="mobile-logout-wrapper d-none mt-5 pt-3 border-top border-secondary">
                <form asp-controller="Dashboard" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger w-100 py-2.5">
                        <i class="bi bi-box-arrow-right me-2"></i>Выйти из аккаунта
                    </button>
                </form>
            </div>

        </main>
    </div>

</body>
</html>
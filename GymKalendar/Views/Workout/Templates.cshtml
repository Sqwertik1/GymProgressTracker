@model IEnumerable<GymKalendar.Models.WorkoutTemplate>

<div class="container mt-4">
    <h2>Мои шаблоны тренировок</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">У тебя пока нет сохраненных шаблонов. Создай их из истории тренировок!</div>
    }
    else
    {
        <div class="row">
            @foreach (var template in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title">@template.Name</h5>
                                <p class="text-muted small">Шаблон готов к запуску</p>
                            </div>

                            <!-- Кнопка запуска. Она дергает твой метод StartWorkoutfromTemplate -->
                            <a asp-controller="Workout"
                               asp-action="StartWorkoutfromTemplate"
                               asp-route-templateId="@template.Id"
                               class="btn btn-success w-100 mt-3">
                                Начать тренировку
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model GymKalendar.Models.Workout

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name — GymKalendar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            /* Глобальные стили темной темы GymKalendar */
            body {
                background-color: #12141c;
                color: #f8f9fa;
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                padding: 40px 0;
            }

            .container {
                max-width: 800px;
            }

            .text-light-muted {
                color: #a0aec0;
            }

            .text-accent-blue {
                color: #3b82f6;
            }

            /* Кнопка Назад */
            .btn-back {
                color: #a0aec0;
                text-decoration: none;
                font-weight: 500;
                transition: color 0.2s ease;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .btn-back:hover {
                    color: #ffffff;
                }

            /* Главная карточка тренировки */
            .workout-main-card {
                background-color: #1a1f2c;
                border-radius: 16px;
                box-shadow: 0 4px 25px rgba(0, 0, 0, 0.3);
                border-left: 4px solid #3b82f6;
            }

            /* Карточки упражнений */
            .exercise-list-card {
                background-color: #1a1f2c;
                border-radius: 16px;
                box-shadow: 0 4px 25px rgba(0, 0, 0, 0.3);
            }

            .exercise-item {
                background-color: #131722;
                border: 1px solid #2d3748;
                border-radius: 12px;
                transition: border-color 0.2s ease;
            }

                .exercise-item:hover {
                    border-color: #3b82f6;
                }

            .exercise-badge {
                background-color: rgba(59, 130, 246, 0.1);
                color: #60a5fa;
                border: 1px solid rgba(59, 130, 246, 0.2);
                font-weight: 600;
                padding: 6px 12px;
                border-radius: 8px;
            }
    </style>
</head>
<body>

    <div class="container px-3">

        <div class="mb-4">
            <a href="/Dashboard/Index" class="btn-back">
                <i class="bi bi-arrow-left"></i> Назад в кабинет
            </a>
        </div>

        <a asp-controller="Workout"
           asp-action="CreateTemplateFromWorkout"
           asp-route-workoutId="@Model.Id"
           class="btn btn-outline-primary btn-sm">
            Сохранить как шаблон
        </a>

        <div class="card workout-main-card border-0 mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <h1 class="h2 fw-bold text-light m-0">@Model.Name</h1>
                    <span class="badge bg-dark-subtle text-accent-blue border border-primary-subtle py-2 px-3 rounded-pill fs-6">
                        <i class="bi bi-calendar3 me-2"></i>@Model.Date.ToString("dd.MM.yyyy")
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-light-muted m-0 p-3 rounded-3" style="background-color: #131722; border: 1px solid #2d3748;">
                        @Model.Description
                    </p>
                }
                else
                {
                    <p class="text-muted italic m-0">Описание к этой тренировке не оставлено.</p>
                }
            </div>
        </div>

        <div class="card exercise-list-card border-0">
            <div class="card-body p-4">
                <h2 class="h4 text-light fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="bi bi-list-task text-accent-blue"></i> Программа упражнений
                </h2>

                @if (Model.Exercises == null || Model.Exercises.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-exclamation-circle d-block mb-2 fs-3"></i>
                        В этой тренировке пока нет упражнений.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @for (int i = 0; i < Model.Exercises.Count; i++)
                        {
                            var exercise = Model.Exercises[i];
                            <div class="exercise-item p-3">
                                <div class="row align-items-center g-3">
                                    <div class="col-12 col-md-6 d-flex align-items-center gap-3">
                                        <span class="text-muted fw-bold font-monospace">#@(i + 1)</span>
                                        <h3 class="h5 text-light m-0 fw-semibold">@exercise.NameOfExercise</h3>
                                    </div>

                                    <div class="col-12 col-md-6 text-md-end d-flex justify-content-md-end gap-3">
                                        <div class="exercise-badge">
                                            <span class="small text-light-muted fw-normal me-1">Повторы:</span>
                                            <span>@(!string.IsNullOrEmpty(exercise.Reps?.ToString()) && exercise.Reps.ToString() != "0" ? exercise.Reps : "—")</span>
                                        </div>
                                        <div class="exercise-badge">
                                            <span class="small text-light-muted fw-normal me-1">Вес:</span>
                                            <span>@(!string.IsNullOrEmpty(exercise.Weight?.ToString()) && exercise.Weight.ToString() != "0" ? $"{exercise.Weight} кг" : "—")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>

    </div>

</body>
</html>